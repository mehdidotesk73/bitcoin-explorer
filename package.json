{
  "name": "bitcoin1460",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Vue + Vite web app, installable as a PWA and Capacitor-ready for native iOS/Android builds.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-pwa-assets": "pwa-assets-generator",
    "cap:sync": "cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "marked": "^18.0.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@vite-pwa/assets-generator": "^0.2.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "prettier": "3.8.4",
    "typescript": "^6.0.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  }
}
